  "codigos": {
    "escenas": [
      {
        "nombre": "escena1",
        "codigo": "class escena1 extends Escena {\n  iniciar() {\n    this.pilas.definir_mapa({\n      1: \"p1\",\n      2: \"p2\",\n      3: \"p3\",\n      4: \"p4\",\n      5: \"p5\",\n    });\n\n    this.pilas.crear_mapa(`\n    4..........................................54......\n    4..........................................54......\n    4..........................................54......\n    4..........................................54......\n    4..........................................54......\n    4................54........................54......\n    4................54........................54......\n    4...........111111111111111111.............54......\n    4...........333333333333333333111..........54......\n    111111111111333333333333333333333111111111111111111\n    333333333333333333333333333333333333333333333333333\n    `, 16, 240, 0)\n  }\n\n  actualizar() {\n\n  }\n}"
      }
    ],
    "actores": [
      {
        "nombre": "mario",
        "codigo": "// @ts-ignore\nclass mario extends Actor {\n  contador: number; /* sirve para conocer si el actor estuvo \n                       caminando mas de 1 segundo, si es así\n                       sirve para que pueda comenzar a correr */\n  vy = 0; // velocidad vertical\n  vx = 0; // velocidad de movimiento horizontal en el salto\n  pies: Laser;\n  derecha: Laser;\n  izquierda: Laser;\n\n  distancia_al_suelo: number;\n  distancia_derecha = 0;   // distancia a paredes\n  distancia_izquierda = 0; // distancia a paredes\n\n  iniciar() {\n    this.estado = \"salta\";\n    this.pies = this.obtener_laser(\"pies\");\n    this.derecha = this.obtener_laser(\"derecha\");\n    this.izquierda = this.obtener_laser(\"izquierda\");\n  }\n\n  actualizar() {\n    this.pilas.camara.seguir_al_actor(this);\n    this.distancia_al_suelo = this.pies.distancia_al_actor_con_etiqueta(\"suelo\");\n\n    this.distancia_derecha = this.derecha.distancia_al_actor_con_etiqueta(\"suelo\");\n    this.distancia_izquierda = this.izquierda.distancia_al_actor_con_etiqueta(\"suelo\");\n\n    //this.pilas.observar(\"distancia_al_suelo\", this.distancia_al_suelo);\n    //this.pilas.observar(\"distancia_derecha\", this.distancia_derecha);\n    //this.pilas.observar(\"distancia_izquierda\", this.distancia_izquierda);\n    //this.pilas.observar(\"vy\", this.vy);\n  }\n\n  parado_iniciar() {\n    this.animacion = \"parado\";\n  }\n\n  parado_actualizar() {\n    if (this.control.izquierda) {\n      this.espejado = true;\n      this.estado = \"camina\";\n    }\n    if (this.control.derecha) {\n      this.espejado = false;\n      this.estado = \"camina\";\n    }\n\n    if (this.control.arriba) {\n      this.iniciar_salto();\n    }\n  }\n\n  camina_iniciar() {\n    this.animacion = \"camina\";\n    this.contador = 0;\n  }\n\n  caer() {\n    this.estado = \"salta\";\n    this.vy = 0;\n  }\n\n  mover_horizontalmente(velocidad = 0) {\n    // intenta moverse a la izquieda o derecha pero sin\n    // sobrepasar las paredes.\n\n    if (velocidad < 0) {\n      // mueve hacia la izquierda\n      this.espejado = true;\n\n      if (this.distancia_izquierda - 10 < -velocidad) {\n        this.x -= this.distancia_izquierda - 10;\n      } else {\n        this.x += velocidad;\n      }\n    } else {\n      // mueve hacia la derecha\n      this.espejado = false;\n\n      if (this.distancia_derecha < velocidad) {\n        this.x += this.distancia_derecha;\n      } else {\n        this.x += velocidad;\n      }\n\n    }\n  }\n\n  camina_actualizar() {\n    this.contador += 1;\n\n    if (this.control.izquierda) {\n      this.mover_horizontalmente(-2);\n    }\n\n    if (this.control.derecha) {\n      this.mover_horizontalmente(2);\n    }\n\n    if (this.control.arriba) {\n      this.iniciar_salto();\n    }\n\n    if (!this.control.izquierda && !this.control.derecha) {\n      this.estado = \"parado\"\n    }\n\n    if (this.contador > 30) {\n      // si pasó mas de un segundo caminando, empieza a correr!!!\n      this.estado = \"corre\";\n    }\n\n    if (this.distancia_al_suelo > 20) {\n      // si no está tocando el suelo comienza a caer\n      this.caer();\n    }\n  }\n\n  corre_iniciar() {\n    this.animacion = \"corre\";\n  }\n\n  corre_actualizar() {\n    if (this.control.izquierda) {\n      this.mover_horizontalmente(-3);\n    }\n\n    if (this.control.derecha) {\n      this.mover_horizontalmente(3);\n    }\n\n    if (this.control.arriba) {\n      this.iniciar_salto(3);\n    }\n\n    if (!this.control.izquierda && !this.control.derecha) {\n      this.estado = \"parado\"\n    }\n    if (this.distancia_al_suelo > 20) {\n      // si no está tocando el suelo comienza a caer\n      this.caer();\n    }\n  }\n\n\n  salta_iniciar() {\n    this.animacion = \"salta\";\n  }\n\n  salta_actualizar() {\n    this.distancia_al_suelo = this.pies.distancia_al_actor_con_etiqueta(\"suelo\");\n\n    if (this.control.izquierda) {\n      this.mover_horizontalmente(-this.vx);\n      //this.x -= this.vx;\n      //this.espejado = true;\n    }\n\n    if (this.control.derecha) {\n      this.mover_horizontalmente(this.vx);\n      //this.x += this.vx;\n      //this.espejado = false;\n    }\n\n    if (this.vy < 0 && this.distancia_al_suelo - 17 < -this.vy) {\n      this.y -= this.distancia_al_suelo - 17;\n      this.vy = 0;\n      this.estado = \"parado\";\n    } else {\n      this.y += this.vy;\n      this.vy -= 0.35;\n    }\n  }\n\n  iniciar_salto(velocidad = 2) {\n    this.estado = \"salta\";\n    this.vx = velocidad;\n    this.vy = 8;\n  }\n}\n"
      },
      {
