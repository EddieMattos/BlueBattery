        "codigo": "// @ts-ignore\nclass nube_animada extends Actor {\n\n  velocidad: number;\n\n  iniciar() {\n    this.z = 50;\n    this.velocidad = 0.5;\n  }\n\n  actualizar() {\n    this.x -= this.velocidad;\n\n    if (this.x < -400) {\n      this.x = 400;\n      this.y = this.pilas.azar(-200, 200);\n    }\n  }\n}\n"
